    {
      "id": "custom-cat-blast-mms2fr2j",
      "name": "Cat Blast",
      "emoji": "😺",
      "description": "Drag cat-shaped blocks onto the board to fill rows and columns — hear the meows when you clear lines!",
      "bg": "linear-gradient(135deg,#0f766e,#0d9488)",
      "accent": "#2dd4bf",
      "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no\">\n<meta name=\"game-name\"        content=\"Cat Blast\">\n<meta name=\"game-emoji\"       content=\"😺\">\n<meta name=\"game-description\" content=\"Drag cat-shaped blocks onto the board to fill rows and columns — hear the meows when you clear lines!\">\n<title>Cat Blast 😺</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Fredoka+One&display=swap\" rel=\"stylesheet\">\n<style>\n*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\nhtml,body{\n  width:100%;height:100dvh;overflow:hidden;\n  background:radial-gradient(ellipse at 22% 18%,#2e156a 0%,#0c0620 50%,#050112 100%);\n  display:flex;flex-direction:column;align-items:center;\n  font-family:'Fredoka One',cursive;\n  touch-action:none;\n  -webkit-user-select:none;user-select:none;\n  -webkit-tap-highlight-color:transparent;\n}\n@keyframes tw{0%,100%{opacity:.1}50%{opacity:.9}}\n.star{position:fixed;background:#fff;border-radius:50%;pointer-events:none;z-index:0}\n\n/* header */\n#hdr{\n  width:100%;display:flex;align-items:center;justify-content:space-between;\n  padding:max(env(safe-area-inset-top,0px),10px) 14px 5px;\n  flex-shrink:0;position:relative;z-index:10;\n}\n.scores{display:flex;gap:8px}\n.sbox{\n  background:rgba(255,255,255,.07);border:1.5px solid rgba(255,255,255,.12);\n  border-radius:12px;padding:3px 16px;text-align:center;min-width:68px;\n}\n.slabel{font-size:.5rem;color:rgba(255,255,255,.38);letter-spacing:2px;text-transform:uppercase;display:block}\n.sval{font-size:1.5rem;color:#FFD700;line-height:1.1;display:block}\n#muteBtn{\n  background:rgba(255,255,255,.08);border:1.5px solid rgba(255,255,255,.16);\n  border-radius:50%;width:38px;height:38px;font-size:1.1rem;\n  display:flex;align-items:center;justify-content:center;\n  flex-shrink:0;cursor:pointer;\n}\n\n/* board */\n#boardWrap{flex-shrink:0;position:relative;z-index:10;display:flex;align-items:center;justify-content:center}\n#board{display:block;border-radius:10px;box-shadow:0 0 40px rgba(90,40,200,.4)}\n\n/* tray */\n#tray{\n  display:flex;justify-content:center;align-items:center;\n  gap:8px;padding:8px 12px;\n  padding-bottom:max(env(safe-area-inset-bottom,8px),8px);\n  flex-shrink:0;z-index:10;position:relative;width:100%;\n}\n.slot{\n  border:2px solid rgba(255,255,255,.10);border-radius:12px;\n  background:rgba(255,255,255,.04);\n  display:flex;align-items:center;justify-content:center;\n  flex-shrink:0;transition:border-color .15s,background .15s,transform .12s;\n  cursor:grab;\n}\n.slot.lift{border-color:rgba(255,210,0,.55);background:rgba(255,210,0,.07);transform:scale(1.05)}\n.slot.empty{opacity:.18;cursor:default;pointer-events:none}\n\n/* drag ghost */\n#drag{\n  position:fixed;pointer-events:none;display:none;z-index:999;\n  filter:drop-shadow(0 10px 28px rgba(0,0,0,.65));opacity:.92;\n  will-change:left,top;\n}\n\n/* combo */\n#combo{\n  position:fixed;pointer-events:none;z-index:600;\n  font-size:clamp(1.3rem,5.5vw,2rem);color:#FFD700;\n  text-shadow:0 0 20px rgba(255,200,0,.9),2px 2px 0 #c0187a;\n  display:none;left:50%;top:34%;transform:translate(-50%,-50%);white-space:nowrap;\n}\n@keyframes comboFly{\n  0%  {opacity:0;transform:translate(-50%,-50%) scale(.25) rotate(-10deg)}\n  22% {opacity:1;transform:translate(-50%,-50%) scale(1.3) rotate(4deg)}\n  55% {transform:translate(-50%,-50%) scale(1) rotate(0)}\n  78% {opacity:1;transform:translate(-50%,-64%) scale(.95)}\n  100%{opacity:0;transform:translate(-50%,-84%) scale(.82)}\n}\n\n/* game over */\n#go{\n  display:none;position:fixed;inset:0;\n  background:rgba(3,0,12,.88);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);\n  flex-direction:column;align-items:center;justify-content:center;\n  gap:18px;z-index:800;text-align:center;padding:28px;\n}\n#go.show{display:flex}\n.go-paws{font-size:3rem;animation:pawB .6s ease forwards}\n@keyframes pawB{0%{transform:scale(0) rotate(-20deg)}70%{transform:scale(1.2) rotate(5deg)}100%{transform:scale(1) rotate(0)}}\n.go-title{font-size:clamp(2rem,8vw,3.2rem);color:#FFD700;text-shadow:0 0 32px rgba(255,200,0,.85),2px 3px 0 #6a28b8}\n.go-label{color:rgba(255,255,255,.5);font-size:.75rem;letter-spacing:3px;text-transform:uppercase}\n.go-score{color:#FFD700;font-size:clamp(2rem,10vw,3rem);line-height:1.1;display:block}\n.go-best{color:rgba(255,255,255,.4);font-size:.75rem;letter-spacing:2px;margin-top:4px}\n.go-best span{color:rgba(255,200,80,.7)}\n.go-btn{\n  background:linear-gradient(135deg,#7b2fbe,#d81b7c);color:#fff;border:none;\n  padding:14px 48px;border-radius:50px;font-family:'Fredoka One',cursive;\n  font-size:1.25rem;cursor:pointer;box-shadow:0 6px 28px rgba(120,40,190,.55);\n  transition:transform .14s,box-shadow .14s;\n}\n.go-btn:active{transform:scale(.95)}\n</style>\n</head>\n<body>\n\n<div id=\"hdr\">\n  <div class=\"scores\">\n    <div class=\"sbox\"><span class=\"slabel\">Score</span><span class=\"sval\" id=\"scoreEl\">0</span></div>\n    <div class=\"sbox\"><span class=\"slabel\">Best</span><span class=\"sval\"  id=\"bestEl\">0</span></div>\n  </div>\n  <button id=\"muteBtn\" onclick=\"toggleMute()\" aria-label=\"Toggle sound\">🔊</button>\n</div>\n\n<div id=\"boardWrap\"><canvas id=\"board\"></canvas></div>\n\n<div id=\"tray\">\n  <div class=\"slot\" id=\"s0\"><canvas id=\"pc0\"></canvas></div>\n  <div class=\"slot\" id=\"s1\"><canvas id=\"pc1\"></canvas></div>\n  <div class=\"slot\" id=\"s2\"><canvas id=\"pc2\"></canvas></div>\n</div>\n\n<canvas id=\"drag\"></canvas>\n<div id=\"combo\"></div>\n\n<div id=\"go\">\n  <div class=\"go-paws\">😿</div>\n  <div class=\"go-title\">Game Over!</div>\n  <div>\n    <div class=\"go-label\">Final Score</div>\n    <span class=\"go-score\" id=\"finalScore\">0</span>\n    <div class=\"go-best\">Best: <span id=\"goBest\">0</span></div>\n  </div>\n  <button class=\"go-btn\" onclick=\"startGame()\">Play Again 🐾</button>\n</div>\n\n<script>\n'use strict';\n\n/* ═══════════════════════════════════════════════════\n   STARS\n═══════════════════════════════════════════════════ */\n(function(){\n  const f=document.createDocumentFragment();\n  for(let i=0;i<80;i++){\n    const s=document.createElement('div');\n    s.className='star';\n    const z=(Math.random()*2.2+.3).toFixed(1);\n    s.style.cssText=`width:${z}px;height:${z}px;`\n      +`left:${(Math.random()*100).toFixed(2)}%;`\n      +`top:${(Math.random()*100).toFixed(2)}%;`\n      +`animation:tw ${(Math.random()*4+2).toFixed(1)}s `\n      +`${(Math.random()*4).toFixed(1)}s infinite ease-in-out`;\n    f.appendChild(s);\n  }\n  document.body.appendChild(f);\n})();\n\n/* ═══════════════════════════════════════════════════\n   AUDIO  (Web Audio synthesis — no files needed)\n═══════════════════════════════════════════════════ */\nlet _ctx=null, muted=false;\nfunction getAudio(){\n  if(!_ctx) _ctx=new(window.AudioContext||window.webkitAudioContext)();\n  if(_ctx.state==='suspended') _ctx.resume();\n  return _ctx;\n}\nfunction toggleMute(){\n  muted=!muted;\n  document.getElementById('muteBtn').textContent=muted?'🔇':'🔊';\n}\nfunction synthMeow(pitch,vowel,delay){\n  if(muted)return;\n  pitch=pitch||1; vowel=vowel??0.6; delay=delay||0;\n  const ctx=getAudio(),t=ctx.currentTime+delay;\n  const master=ctx.createGain();\n  master.gain.setValueAtTime(0,t);\n  master.gain.linearRampToValueAtTime(.28,t+.06);\n  master.gain.setValueAtTime(.28,t+.22);\n  master.gain.exponentialRampToValueAtTime(.001,t+.52);\n  master.connect(ctx.destination);\n  const osc=ctx.createOscillator(); osc.type='sawtooth';\n  const bf=420*pitch;\n  osc.frequency.setValueAtTime(bf*.70,t);\n  osc.frequency.linearRampToValueAtTime(bf,t+.10);\n  osc.frequency.linearRampToValueAtTime(bf*1.30,t+.22);\n  osc.frequency.exponentialRampToValueAtTime(bf*(.60+vowel*.28),t+.45);\n  const form=ctx.createBiquadFilter(); form.type='bandpass'; form.Q.value=3.5;\n  form.frequency.setValueAtTime(900*pitch,t);\n  form.frequency.linearRampToValueAtTime(1800*pitch,t+.18);\n  form.frequency.exponentialRampToValueAtTime(600*pitch,t+.44);\n  const shelf=ctx.createBiquadFilter(); shelf.type='highshelf'; shelf.frequency.value=3200; shelf.gain.value=-10;\n  const vib=ctx.createOscillator(); vib.frequency.value=6.5;\n  const vg=ctx.createGain();\n  vg.gain.setValueAtTime(0,t); vg.gain.linearRampToValueAtTime(12*pitch,t+.15);\n  vg.gain.setValueAtTime(12*pitch,t+.30); vg.gain.linearRampToValueAtTime(0,t+.46);\n  vib.connect(vg); vg.connect(osc.frequency);\n  osc.connect(form); form.connect(shelf); shelf.connect(master);\n  osc.start(t); osc.stop(t+.56); vib.start(t); vib.stop(t+.56);\n  const n=ctx.createOscillator(); n.type='sawtooth'; n.frequency.value=bf*3.1;\n  const ng=ctx.createGain(); ng.gain.setValueAtTime(.04,t); ng.gain.linearRampToValueAtTime(0,t+.12);\n  n.connect(ng); ng.connect(master); n.start(t); n.stop(t+.15);\n}\nfunction playPlop(){\n  if(muted)return;\n  const ctx=getAudio(),t=ctx.currentTime;\n  const o=ctx.createOscillator(); o.type='sine';\n  o.frequency.setValueAtTime(180,t); o.frequency.exponentialRampToValueAtTime(55,t+.12);\n  const g=ctx.createGain(); g.gain.setValueAtTime(.13,t); g.gain.exponentialRampToValueAtTime(.001,t+.14);\n  o.connect(g); g.connect(ctx.destination); o.start(t); o.stop(t+.16);\n}\nfunction playMeow(lines){\n  if(muted)return;\n  const n=Math.min(lines,5);\n  const P=[1,1.15,.88,1.28,.95], V=[.55,.70,.45,.80,.60];\n  const gap=lines>=4?.22:lines>=3?.28:.32;\n  for(let i=0;i<n;i++) synthMeow(P[i%5]*(lines>=3?1.12:1),V[i%5],i*gap);\n}\nfunction playGameOver(){\n  if(muted)return;\n  synthMeow(.75,.2,0); synthMeow(.58,.1,.46);\n}\n\n/* ═══════════════════════════════════════════════════\n   SIZING  (mobile-first, recalculated on resize)\n═══════════════════════════════════════════════════ */\nconst GRID=8;\nlet CELL=44, SLOT=108;\n\nfunction calcSizes(){\n  const vw=Math.min(window.innerWidth,520);\n  const vh=window.innerHeight;\n  const hdrH=document.getElementById('hdr').getBoundingClientRect().height||52;\n  const avW=vw-20;                       // board canvas max width\n  const slotEst=Math.floor((avW-16)/3);  // estimated slot size\n  const trayH=slotEst+26;                // tray total height\n  const avH=vh-hdrH-trayH-10;           // height available for board\n  CELL=Math.max(28,Math.min(58,Math.floor(Math.min(avW,avH)/GRID)));\n  SLOT=Math.floor((CELL*GRID-16)/3);\n}\n\n/* ═══════════════════════════════════════════════════\n   BREEDS  (7 cats, distinct colour + pattern each)\n═══════════════════════════════════════════════════ */\nconst BREEDS=[\n  {name:'Orange Tabby',bg:'#C85A1A',stripe:'#8C2E06', earIn:'#E08080',eyeC:'#C8980A',nose:'#FF8888', pattern:'tabby'  },\n  {name:'Tuxedo',      bg:'#181828',belly:'#FFFFFF',  earIn:'#FF8080',eyeC:'#00E070',nose:'#FFB0C0', pattern:'tuxedo' },\n  {name:'Calico',      bg:'#F0DDBC',patch1:'#C85A1A', patch2:'#181828',earIn:'#FF8888',eyeC:'#29BEFF',nose:'#FFAAB8',pattern:'calico' },\n  {name:'Siamese',     bg:'#EDD9B0',points:'#58300C', earIn:'#C09090',eyeC:'#45D0E0',nose:'#E898B0', pattern:'siamese'},\n  {name:'Russian Blue',bg:'#5A7898',dark:'#364E64',   belly:'#85AAC0',earIn:'#7858C0',eyeC:'#5DDA78',nose:'#C090D8',pattern:'blue'   },\n  {name:'Flame Point', bg:'#FFF0D0',flame:'#FF5200',  earIn:'#FFBCA8',eyeC:'#20C0D8',nose:'#FFB0C0', pattern:'flame'  },\n  {name:'Snow Bengal', bg:'#E8E3DA',spots:'#9A8060',  earIn:'#FFBCA8',eyeC:'#7AD8FF',nose:'#FFBCA8', pattern:'bengal' },\n];\nconst B_SPOTS=[[.20,.24,.52],[.72,.20,1.22],[.15,.66,.30],[.76,.60,.86],[.45,.46,1.56],[.36,.78,.10],[.65,.82,.92]];\n\n/* ═══════════════════════════════════════════════════\n   SHAPES  (breed 0-6 matched to shape families)\n═══════════════════════════════════════════════════ */\nconst SHAPES=[\n  // Siamese — sleek I-pieces\n  {cells:[[0,0]],b:3},\n  {cells:[[0,0],[0,1],[0,2],[0,3]],b:3},\n  {cells:[[0,0],[1,0],[2,0],[3,0]],b:3},\n  {cells:[[0,0],[0,1],[0,2],[0,3],[0,4]],b:3},\n  {cells:[[0,0],[1,0],[2,0],[3,0],[4,0]],b:3},\n  // Orange Tabby — dominoes + S/Z\n  {cells:[[0,0],[0,1]],b:0},\n  {cells:[[0,0],[1,0]],b:0},\n  {cells:[[0,0],[0,1],[1,1],[1,2]],b:0},\n  {cells:[[0,1],[0,2],[1,0],[1,1]],b:0},\n  // Tuxedo — 3-bar + 2×3 blocks\n  {cells:[[0,0],[0,1],[0,2]],b:1},\n  {cells:[[0,0],[1,0],[2,0]],b:1},\n  {cells:[[0,0],[0,1],[1,0],[1,1],[2,0],[2,1]],b:1},\n  {cells:[[0,0],[0,1],[0,2],[1,0],[1,1],[1,2]],b:1},\n  // Calico — L-corners + big-L 5-cell\n  {cells:[[0,0],[1,0],[1,1]],b:2},\n  {cells:[[0,1],[1,0],[1,1]],b:2},\n  {cells:[[0,0],[0,1],[1,0]],b:2},\n  {cells:[[0,0],[0,1],[1,1]],b:2},\n  {cells:[[0,0],[1,0],[2,0],[3,0],[3,1]],b:2},\n  {cells:[[0,0],[0,1],[0,2],[0,3],[1,0]],b:2},\n  // Russian Blue — 2×2 square\n  {cells:[[0,0],[0,1],[1,0],[1,1]],b:4},\n  // Flame Point — T-shapes + plus\n  {cells:[[0,0],[0,1],[0,2],[1,1]],b:5},\n  {cells:[[0,1],[1,0],[1,1],[2,1]],b:5},\n  {cells:[[0,1],[1,0],[1,1],[1,2]],b:5},\n  {cells:[[1,0],[1,1],[1,2],[0,1]],b:5},\n  {cells:[[0,1],[1,0],[1,1],[1,2],[2,1]],b:5},\n  // Snow Bengal — L 4-cell + 3×3 square\n  {cells:[[0,0],[1,0],[2,0],[2,1]],b:6},\n  {cells:[[0,0],[0,1],[1,0],[2,0]],b:6},\n  {cells:[[0,1],[1,1],[2,0],[2,1]],b:6},\n  {cells:[[0,0],[1,0],[1,1],[1,2]],b:6},\n  {cells:[[0,0],[0,1],[0,2],[1,0],[1,1],[1,2],[2,0],[2,1],[2,2]],b:6},\n];\n\n/* ═══════════════════════════════════════════════════\n   STATE\n═══════════════════════════════════════════════════ */\nlet board=[], pieces=[null,null,null];\nlet score=0, best=parseInt(localStorage.getItem('catblast_best')||'0');\nlet drag=null, boardHL=null;\n\nconst bCanvas=document.getElementById('board');\nconst bCtx=bCanvas.getContext('2d');\nconst dCanvas=document.getElementById('drag');\nconst dCtx=dCanvas.getContext('2d');\n\n/* ═══════════════════════════════════════════════════\n   DRAWING HELPERS\n═══════════════════════════════════════════════════ */\nfunction rrPath(ctx,x,y,w,h,r){\n  ctx.beginPath();\n  ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y);\n  ctx.arcTo(x+w,y,x+w,y+r,r); ctx.lineTo(x+w,y+h-r);\n  ctx.arcTo(x+w,y+h,x+w-r,y+h,r); ctx.lineTo(x+r,y+h);\n  ctx.arcTo(x,y+h,x,y+h-r,r); ctx.lineTo(x,y+r);\n  ctx.arcTo(x,y,x+r,y,r); ctx.closePath();\n}\nfunction drawPattern(ctx,x,y,w,h,b){\n  ctx.save(); rrPath(ctx,x,y,w,h,6); ctx.clip();\n  const cx=x+w/2,cy=y+h/2;\n  switch(b.pattern){\n    case 'tabby':\n      ctx.fillStyle=b.stripe;\n      [[.30,.055],[.51,.055],[.72,.055]].forEach(([yf,hf])=>ctx.fillRect(x,y+h*yf,w,h*hf));\n      ctx.fillRect(cx-w*.28,y+h*.06,w*.09,h*.12);\n      ctx.fillRect(cx-w*.07,y+h*.04,w*.07,h*.10);\n      ctx.fillRect(cx+w*.08,y+h*.06,w*.09,h*.12);\n      break;\n    case 'tuxedo':\n      ctx.fillStyle=b.belly;\n      ctx.beginPath(); ctx.ellipse(cx,cy+h*.28,w*.26,h*.30,0,0,Math.PI*2); ctx.fill();\n      ctx.beginPath(); ctx.ellipse(cx,cy+h*.16,w*.34,h*.22,0,0,Math.PI*2); ctx.fill();\n      break;\n    case 'calico':\n      ctx.fillStyle=b.patch1;\n      ctx.beginPath(); ctx.ellipse(x+w*.24,y+h*.35,w*.22,h*.28,.50,0,Math.PI*2); ctx.fill();\n      ctx.fillStyle=b.patch2;\n      ctx.beginPath(); ctx.ellipse(x+w*.76,y+h*.65,w*.20,h*.22,-.30,0,Math.PI*2); ctx.fill();\n      ctx.beginPath(); ctx.ellipse(x+w*.62,y+h*.22,w*.15,h*.16,.80,0,Math.PI*2); ctx.fill();\n      break;\n    case 'siamese':\n      ctx.fillStyle=b.points;\n      ctx.beginPath(); ctx.ellipse(cx,cy+h*.10,w*.32,h*.23,0,0,Math.PI*2); ctx.fill();\n      ctx.beginPath(); ctx.ellipse(cx-w*.24,y+h*.07,w*.10,h*.09,0,0,Math.PI*2); ctx.fill();\n      ctx.beginPath(); ctx.ellipse(cx+w*.24,y+h*.07,w*.10,h*.09,0,0,Math.PI*2); ctx.fill();\n      break;\n    case 'blue':{\n      const g=ctx.createRadialGradient(cx,cy,0,cx,cy,w*.66);\n      g.addColorStop(0,b.belly); g.addColorStop(1,b.dark);\n      ctx.fillStyle=g; ctx.fillRect(x,y,w,h); break;}\n    case 'flame':\n      ctx.fillStyle=b.flame;\n      ctx.beginPath(); ctx.ellipse(cx-w*.22,y+h*.17,w*.11,h*.10,0,0,Math.PI*2); ctx.fill();\n      ctx.beginPath(); ctx.ellipse(cx+w*.22,y+h*.17,w*.11,h*.10,0,0,Math.PI*2); ctx.fill();\n      ctx.beginPath(); ctx.ellipse(cx,y+h*.82,w*.17,h*.10,0,0,Math.PI*2); ctx.fill();\n      break;\n    case 'bengal':\n      ctx.fillStyle=b.spots;\n      B_SPOTS.forEach(([sx,sy,a])=>{\n        ctx.beginPath(); ctx.ellipse(x+w*sx,y+h*sy,w*.10,h*.07,a,0,Math.PI*2); ctx.fill();\n      });\n      break;\n  }\n  ctx.restore();\n}\nfunction drawCat(ctx,px,py,size,bIdx){\n  const b=BREEDS[bIdx];\n  const pad=size>30?2:1;\n  const x=px+pad,y=py+pad,w=size-pad*2,h=size-pad*2;\n  const cx=x+w/2,cy=y+h/2;\n  const small=size<28;\n  ctx.save();\n  rrPath(ctx,x,y,w,h,small?4:6);\n  ctx.fillStyle=b.bg; ctx.fill();\n  ctx.strokeStyle='rgba(255,255,255,.22)'; ctx.lineWidth=1; ctx.stroke();\n  drawPattern(ctx,x,y,w,h,b);\n  if(!small){\n    const ew=w*.26,eh=h*.18,eby=y+h*.14;\n    function ear(ex){\n      ctx.fillStyle=b.bg;\n      ctx.beginPath(); ctx.moveTo(ex,eby); ctx.lineTo(ex+ew,eby); ctx.lineTo(ex+ew/2,eby-eh); ctx.closePath(); ctx.fill();\n      ctx.fillStyle=b.earIn;\n      const ip=ew*.20;\n      ctx.beginPath(); ctx.moveTo(ex+ip,eby-1); ctx.lineTo(ex+ew-ip,eby-1); ctx.lineTo(ex+ew/2,eby-eh*.65); ctx.closePath(); ctx.fill();\n    }\n    ear(x+w*.05); ear(x+w*.69);\n  }\n  const fy=cy+h*.06;\n  const erx=w*(small?.14:.11),ery=h*(small?.14:.125);\n  const elX=cx-w*.20,erX=cx+w*.20,eyY=fy-h*.10;\n  ctx.fillStyle=b.eyeC;\n  ctx.beginPath(); ctx.ellipse(elX,eyY,erx,ery,0,0,Math.PI*2); ctx.fill();\n  ctx.beginPath(); ctx.ellipse(erX,eyY,erx,ery,0,0,Math.PI*2); ctx.fill();\n  if(!small){\n    ctx.fillStyle='#111';\n    ctx.beginPath(); ctx.ellipse(elX,eyY,erx*.33,ery*.88,0,0,Math.PI*2); ctx.fill();\n    ctx.beginPath(); ctx.ellipse(erX,eyY,erx*.33,ery*.88,0,0,Math.PI*2); ctx.fill();\n    ctx.fillStyle='rgba(255,255,255,.75)';\n    ctx.beginPath(); ctx.ellipse(elX-erx*.22,eyY-ery*.28,erx*.26,ery*.26,0,0,Math.PI*2); ctx.fill();\n    ctx.beginPath(); ctx.ellipse(erX-erx*.22,eyY-ery*.28,erx*.26,ery*.26,0,0,Math.PI*2); ctx.fill();\n    const ny=fy+h*.06;\n    ctx.fillStyle=b.nose;\n    ctx.beginPath(); ctx.moveTo(cx,ny+h*.05); ctx.lineTo(cx-w*.07,ny); ctx.lineTo(cx+w*.07,ny); ctx.closePath(); ctx.fill();\n    ctx.strokeStyle='rgba(0,0,0,.42)'; ctx.lineWidth=w*.024; ctx.lineCap='round';\n    ctx.beginPath(); ctx.moveTo(cx,ny+h*.052); ctx.bezierCurveTo(cx-w*.03,ny+h*.10,cx-w*.12,ny+h*.13,cx-w*.14,ny+h*.12); ctx.stroke();\n    ctx.beginPath(); ctx.moveTo(cx,ny+h*.052); ctx.bezierCurveTo(cx+w*.03,ny+h*.10,cx+w*.12,ny+h*.13,cx+w*.14,ny+h*.12); ctx.stroke();\n    ctx.strokeStyle='rgba(255,255,255,.80)'; ctx.lineWidth=.85; ctx.lineCap='round';\n    const wy=ny+h*.022;\n    [-1,0,1].forEach(i=>{\n      ctx.beginPath(); ctx.moveTo(cx-w*.07,wy+i*h*.048); ctx.lineTo(cx-w*.46,wy+i*h*.048+i*h*.018); ctx.stroke();\n      ctx.beginPath(); ctx.moveTo(cx+w*.07,wy+i*h*.048); ctx.lineTo(cx+w*.46,wy+i*h*.048+i*h*.018); ctx.stroke();\n    });\n  } else {\n    ctx.fillStyle='rgba(0,0,0,.7)';\n    ctx.beginPath(); ctx.ellipse(elX,eyY,erx*.4,ery*.4,0,0,Math.PI*2); ctx.fill();\n    ctx.beginPath(); ctx.ellipse(erX,eyY,erx*.4,ery*.4,0,0,Math.PI*2); ctx.fill();\n  }\n  ctx.restore();\n}\n\n/* ═══════════════════════════════════════════════════\n   BOARD RENDER\n═══════════════════════════════════════════════════ */\nfunction drawBoard(){\n  const bp=CELL*GRID;\n  bCtx.clearRect(0,0,bp,bp);\n  rrPath(bCtx,0,0,bp,bp,10);\n  bCtx.fillStyle='rgba(8,4,22,.96)'; bCtx.fill();\n  bCtx.strokeStyle='rgba(255,255,255,.055)'; bCtx.lineWidth=1;\n  for(let i=0;i<=GRID;i++){\n    bCtx.beginPath(); bCtx.moveTo(i*CELL,0);   bCtx.lineTo(i*CELL,bp); bCtx.stroke();\n    bCtx.beginPath(); bCtx.moveTo(0,i*CELL);   bCtx.lineTo(bp,i*CELL); bCtx.stroke();\n  }\n  if(boardHL){\n    const allOk=boardHL.every(h=>h.ok);\n    boardHL.filter(h=>h.r>=0&&h.r<GRID&&h.c>=0&&h.c<GRID).forEach(({r,c})=>{\n      bCtx.fillStyle=allOk?'rgba(60,255,110,.19)':'rgba(255,55,55,.16)';\n      bCtx.fillRect(c*CELL+1,r*CELL+1,CELL-2,CELL-2);\n      if(allOk){bCtx.strokeStyle='rgba(60,255,110,.45)'; bCtx.lineWidth=1.5; bCtx.strokeRect(c*CELL+1.5,r*CELL+1.5,CELL-3,CELL-3);}\n    });\n  }\n  for(let r=0;r<GRID;r++)\n    for(let c=0;c<GRID;c++)\n      if(board[r][c]!==null) drawCat(bCtx,c*CELL,r*CELL,CELL,board[r][c]);\n}\n\n/* ═══════════════════════════════════════════════════\n   PIECE UTILS\n═══════════════════════════════════════════════════ */\nfunction pBounds(cells){\n  const rs=cells.map(c=>c[0]),cs=cells.map(c=>c[1]);\n  return{minR:Math.min(...rs),maxR:Math.max(...rs),minC:Math.min(...cs),maxC:Math.max(...cs)};\n}\nfunction drawPreview(idx){\n  const cvs=document.getElementById('pc'+idx);\n  const ctx=cvs.getContext('2d');\n  const sl=document.getElementById('s'+idx);\n  ctx.clearRect(0,0,cvs.width,cvs.height);\n  const p=pieces[idx];\n  if(!p){sl.classList.add('empty');return;}\n  sl.classList.remove('empty');\n  const{minR,maxR,minC,maxC}=pBounds(p.cells);\n  const pW=maxC-minC+1,pH=maxR-minR+1;\n  const pad=10;\n  const cs=Math.min((cvs.width-pad*2)/pW,(cvs.height-pad*2)/pH);\n  const ox=pad+(cvs.width-pad*2-pW*cs)/2;\n  const oy=pad+(cvs.height-pad*2-pH*cs)/2;\n  p.cells.forEach(([r,c])=>drawCat(ctx,ox+(c-minC)*cs,oy+(r-minR)*cs,cs,p.breed));\n}\n\n/* ═══════════════════════════════════════════════════\n   DRAG RENDER\n   The piece hovers ABOVE the finger so it stays visible\n   on touchscreens. Canvas top = clientY - height - LIFT\n═══════════════════════════════════════════════════ */\nconst LIFT=10; // px gap between top of piece and finger tip\n\nfunction renderDragPiece(p,mx,my){\n  const{minR,maxR,minC,maxC}=pBounds(p.cells);\n  const pW=maxC-minC+1,pH=maxR-minR+1;\n  dCanvas.width=pW*CELL; dCanvas.height=pH*CELL;\n  dCtx.clearRect(0,0,dCanvas.width,dCanvas.height);\n  p.cells.forEach(([r,c])=>drawCat(dCtx,(c-minC)*CELL,(r-minR)*CELL,CELL,p.breed));\n  dCanvas.style.left=(mx-pW*CELL/2)+'px';\n  dCanvas.style.top=(my-pH*CELL-LIFT)+'px';\n  dCanvas.style.display='block';\n}\n\n/* ═══════════════════════════════════════════════════\n   BOARD HIT-TEST\n   Align the drag canvas bbox with the board grid,\n   accounting for minC/minR so each cell lands correctly.\n═══════════════════════════════════════════════════ */\nfunction boardPos(p,mx,my){\n  const{minR,maxR,minC,maxC}=pBounds(p.cells);\n  const pW=maxC-minC+1,pH=maxR-minR+1;\n  const rect=bCanvas.getBoundingClientRect();\n  // canvas left = mx - pW*CELL/2  →  col = round((canvasLeft - boardLeft)/CELL) - minC\n  const col=Math.round((mx-pW*CELL/2-rect.left)/CELL)-minC;\n  const row=Math.round((my-pH*CELL-LIFT-rect.top)/CELL)-minR;\n  return{row,col};\n}\nfunction updateHL(p,mx,my){\n  const{row,col}=boardPos(p,mx,my);\n  const ok=canPlace(p,row,col);\n  boardHL=p.cells.map(([r,c])=>({r:row+r,c:col+c,ok}));\n}\n\n/* ═══════════════════════════════════════════════════\n   GAME LOGIC\n═══════════════════════════════════════════════════ */\nfunction canPlace(p,row,col){\n  return p.cells.every(([r,c])=>{\n    const tr=row+r,tc=col+c;\n    return tr>=0&&tr<GRID&&tc>=0&&tc<GRID&&board[tr][tc]===null;\n  });\n}\nfunction canFitAnywhere(p){\n  for(let r=0;r<GRID;r++) for(let c=0;c<GRID;c++) if(canPlace(p,r,c)) return true;\n  return false;\n}\nfunction checkGameOver(){\n  const rem=pieces.filter(p=>p!==null);\n  return rem.length>0&&!rem.some(canFitAnywhere);\n}\nfunction placePiece(p,row,col){\n  p.cells.forEach(([r,c])=>{board[row+r][col+c]=p.breed;});\n  const rowsClr=[],colsClr=[];\n  for(let r=0;r<GRID;r++) if(board[r].every(v=>v!==null)) rowsClr.push(r);\n  for(let c=0;c<GRID;c++) if(board.every(row=>row[c]!==null)) colsClr.push(c);\n  const total=rowsClr.length+colsClr.length;\n  let pts=p.cells.length*10;\n  if(total>0){\n    pts+=total*100*Math.max(total,1);\n    showCombo(total); playMeow(total);\n    animateClear(rowsClr,colsClr,()=>{\n      rowsClr.forEach(r=>{for(let c=0;c<GRID;c++)board[r][c]=null;});\n      colsClr.forEach(c=>{for(let r=0;r<GRID;r++)board[r][c]=null;});\n      drawBoard();\n    });\n  } else { playPlop(); }\n  score+=pts; updateScore();\n}\nfunction animateClear(rows,cols,cb){\n  const cells=new Set();\n  rows.forEach(r=>{for(let c=0;c<GRID;c++)cells.add(r+','+c);});\n  cols.forEach(c=>{for(let r=0;r<GRID;r++)cells.add(r+','+c);});\n  let frame=0;\n  (function tick(){\n    drawBoard();\n    cells.forEach(key=>{\n      const[r,c]=key.split(',').map(Number);\n      bCtx.fillStyle=frame%2===0?'rgba(255,238,50,.88)':'rgba(255,255,255,.28)';\n      bCtx.fillRect(c*CELL,r*CELL,CELL,CELL);\n    });\n    if(++frame<10) requestAnimationFrame(tick); else cb();\n  })();\n}\nfunction updateScore(){\n  document.getElementById('scoreEl').textContent=score;\n  if(score>best){best=score; localStorage.setItem('catblast_best',best); document.getElementById('bestEl').textContent=best;}\n}\nconst MSGS=['Paw-some! 🐾','Purr-fect! 😸','Claw-some! 😻','Fur-ocious! 🐱','MEOW-velous! ✨','CAT-ASTROPHIC! 🎉'];\nfunction showCombo(lines){\n  const el=document.getElementById('combo');\n  el.textContent=MSGS[Math.min(lines-1,MSGS.length-1)]+'  +'+(lines*100*Math.max(lines,1))+'!';\n  el.style.animation='none'; el.style.display='block'; void el.offsetHeight;\n  el.style.animation='comboFly 1.5s ease forwards';\n  setTimeout(()=>{el.style.display='none';},1500);\n}\n\n/* ═══════════════════════════════════════════════════\n   DRAG INTERACTION\n═══════════════════════════════════════════════════ */\nfunction startDrag(idx,mx,my){\n  if(!pieces[idx])return;\n  drag={idx,piece:pieces[idx]};\n  document.getElementById('s'+idx).classList.add('lift');\n  renderDragPiece(pieces[idx],mx,my);\n  updateHL(pieces[idx],mx,my);\n  drawBoard();\n}\nfunction moveDrag(mx,my){\n  if(!drag)return;\n  renderDragPiece(drag.piece,mx,my);\n  updateHL(drag.piece,mx,my);\n  drawBoard();\n}\nfunction endDrag(mx,my){\n  if(!drag)return;\n  const{row,col}=boardPos(drag.piece,mx,my);\n  if(canPlace(drag.piece,row,col)){\n    placePiece(drag.piece,row,col);\n    pieces[drag.idx]=null;\n    if(pieces.every(p=>p===null)) refill();\n    for(let i=0;i<3;i++) drawPreview(i);\n    if(checkGameOver()) setTimeout(gameOver,600);\n  }\n  document.getElementById('s'+drag.idx).classList.remove('lift');\n  dCanvas.style.display='none'; boardHL=null; drag=null;\n  drawBoard();\n}\nfunction cancelDrag(){\n  if(!drag)return;\n  document.getElementById('s'+drag.idx).classList.remove('lift');\n  dCanvas.style.display='none'; boardHL=null; drag=null; drawBoard();\n}\n\n// ── Mouse\nconst tray=document.getElementById('tray');\ntray.addEventListener('mousedown',e=>{\n  const sl=e.target.closest('.slot'); if(!sl) return;\n  const idx=parseInt(sl.id.slice(1)); if(isNaN(idx)) return;\n  e.preventDefault(); startDrag(idx,e.clientX,e.clientY);\n});\nwindow.addEventListener('mousemove',e=>{if(drag) moveDrag(e.clientX,e.clientY);});\nwindow.addEventListener('mouseup',  e=>{if(drag) endDrag(e.clientX,e.clientY);});\n\n// ── Touch\ntray.addEventListener('touchstart',e=>{\n  const sl=e.target.closest('.slot'); if(!sl) return;\n  const idx=parseInt(sl.id.slice(1)); if(isNaN(idx)) return;\n  e.preventDefault();\n  const t=e.touches[0]; startDrag(idx,t.clientX,t.clientY);\n},{passive:false});\nwindow.addEventListener('touchmove',e=>{\n  if(!drag) return; e.preventDefault();\n  const t=e.touches[0]; moveDrag(t.clientX,t.clientY);\n},{passive:false});\nwindow.addEventListener('touchend',e=>{\n  if(!drag) return;\n  const t=e.changedTouches[0]; endDrag(t.clientX,t.clientY);\n});\nwindow.addEventListener('touchcancel',cancelDrag);\n\n/* ═══════════════════════════════════════════════════\n   FLOW\n═══════════════════════════════════════════════════ */\nfunction refill(){\n  for(let i=0;i<3;i++){\n    const s=SHAPES[Math.floor(Math.random()*SHAPES.length)];\n    pieces[i]={cells:s.cells,breed:s.b};\n  }\n}\nfunction gameOver(){\n  playGameOver();\n  document.getElementById('finalScore').textContent=score;\n  document.getElementById('goBest').textContent=best;\n  document.getElementById('go').classList.add('show');\n  window.parent.postMessage({type:'GAME_OVER',score:score},'*');\n}\nfunction startGame(){\n  board=Array.from({length:GRID},()=>Array(GRID).fill(null));\n  score=0; updateScore();\n  pieces=[null,null,null]; refill();\n  document.getElementById('go').classList.remove('show');\n  for(let i=0;i<3;i++) drawPreview(i);\n  drawBoard();\n}\n\n/* ═══════════════════════════════════════════════════\n   INIT + RESPONSIVE RESIZE\n═══════════════════════════════════════════════════ */\nfunction applyLayout(){\n  calcSizes();\n  const bp=CELL*GRID;\n  bCanvas.width=bp; bCanvas.height=bp;\n  for(let i=0;i<3;i++){\n    const sl=document.getElementById('s'+i);\n    sl.style.width=SLOT+'px'; sl.style.height=SLOT+'px';\n    const cv=document.getElementById('pc'+i);\n    cv.width=SLOT; cv.height=SLOT;\n  }\n}\nfunction init(){\n  document.getElementById('bestEl').textContent=best;\n  applyLayout();\n  startGame();\n}\nlet rTimer;\nwindow.addEventListener('resize',()=>{\n  clearTimeout(rTimer);\n  rTimer=setTimeout(()=>{\n    applyLayout(); drawBoard();\n    for(let i=0;i<3;i++) drawPreview(i);\n  },130);\n});\ninit();\n</script>\n</body>\n</html>\n"
    }
  ],
